{
  "log": {
    "loglevel": "none"
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "8.8.8.8"
    ],
    "queryStrategy": "UseIPv4",
    "disableCache": false
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "PLACEHOLDER_UUID",
            "email": "user1"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.microsoft.com:443",
          "serverNames": [
            "www.microsoft.com",
            "microsoft.com"
          ],
          "privateKey": "PLACEHOLDER_PRIVATE_KEY",
          "shortIds": [
            "a57304fa",
            "5151361b2de7d115"
          ],
          "maxTimeDiff": 60000
        },
        "xhttpSettings": {
          "path": "/",
          "mode": "auto"
        }
      },
      "sniffing": {
        "enabled": false,
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {
        "domainStrategy": "UseIPv4"
      },
      "streamSettings": {
        "sockopt": {
          "tcpNoDelay": true,
          "tcpFastOpen": true
        }
      }
    }
  ],
  "policy": {
    "levels": {
      "0": {
        "handshake": 3,
        "connIdle": 180,
        "uplinkOnly": 2,
        "downlinkOnly": 5,
        "bufferSize": 512,
        "statsUserUplink": false,
        "statsUserDownlink": false
      }
    }
  }
}